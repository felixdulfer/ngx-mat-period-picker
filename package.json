    "commitizen": "^4.3.2",
    "conventional-changelog-angular": "^9.2.1",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-recommended-bump": "^12.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.7.0",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
